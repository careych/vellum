# Supabase — get these from your Supabase project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin auth — the only email allowed to sign in
ADMIN_EMAIL=your-email@example.com

# Cloudflare R2
# Account ID: Cloudflare Dashboard > R2 > top-right shows "Account ID"
R2_ACCOUNT_ID=your-cloudflare-account-id
# API token: R2 Dashboard > Manage R2 API Tokens > Create token (Object Read & Write)
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# Bucket name (create in R2 dashboard)
R2_BUCKET_NAME=photo-vault-storage
# Public URL: enable r2.dev access on your bucket — Settings > Public Access > Allow Access
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev
